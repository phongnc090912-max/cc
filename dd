    Tooltip = "Help you jump infinitely.",
    Callback = function(state)
        infiniteJumpEnabled = state
        if state then
            enableInfiniteJump()
        else
            disableInfiniteJump()
        end
    end
})

-- ============================================
-- ORBIT UI BOX
-- ============================================

local OrbitBox = Tabs.Fly:AddLeftGroupbox("Orbit")

-- ============================================
-- ORBIT VARIABLES
-- ============================================

local orbitEnabled = false
local orbitConnection = nil
local orbitTarget = nil
local orbitSpeed = 5

-- ============================================
-- GET ROOT
-- ============================================

local function getRoot(player)
    if not player then
        return nil
    end
    local char =
        player.Character
    if not char then
        return nil
    end
    return char:FindFirstChild(
        "HumanoidRootPart"
    )
end

-- ============================================
-- PLAYER LIST
-- ============================================

local orbitPlayerList = {}

local function updateOrbitPlayerList()

    table.clear(
        orbitPlayerList
    )

    for _, player in ipairs(
        Players:GetPlayers()
    ) do

        if player ~= LocalPlayer then

            table.insert(
                orbitPlayerList,
                player.Name
            )
        end
    end

    if Options.OrbitTarget then

        Options.OrbitTarget:SetValues(
            orbitPlayerList
        )
    end
end

Players.PlayerAdded:Connect(function()

    task.wait(1)

    updateOrbitPlayerList()
end)

Players.PlayerRemoving:Connect(function()

    task.wait(1)

    updateOrbitPlayerList()
end)

updateOrbitPlayerList()

-- ============================================
-- ENABLE
-- ============================================

local function enableOrbit()

    if orbitConnection then

        orbitConnection:Disconnect()

        orbitConnection = nil
    end

    orbitConnection =
        RunService.Heartbeat:Connect(function()

            if not orbitEnabled then
                return
            end

            if not orbitTarget then
                return
            end

            local target =
                Players:FindFirstChild(
                    orbitTarget
                )

            if not target then
                return
            end

            local myRoot =
                getRoot(LocalPlayer)

            local targetRoot =
                getRoot(target)

            if not myRoot
            or not targetRoot then
                return
            end

            -- ====================================
            -- CLOSE ORBIT
            -- ====================================

            local radius = 5

            local t =
                tick()
                * orbitSpeed

            local x =
                math.cos(t)
                * radius

            local z =
                math.sin(t)
                * radius

            -- ====================================
            -- FIX UNDERGROUND BUG
            -- ====================================

            local position =
                targetRoot.Position
                + Vector3.new(
                    x,
                    1.5,
                    z
                )

            -- ====================================
            -- MOVE
            -- ====================================

            myRoot.CFrame =
                CFrame.lookAt(
                    position,
                    targetRoot.Position
                )

            myRoot.AssemblyLinearVelocity =
                Vector3.zero
        end)
end

-- ============================================
-- DISABLE
-- ============================================

local function disableOrbit()

    if orbitConnection then

        orbitConnection:Disconnect()

        orbitConnection = nil
    end
end

-- ============================================
-- TOGGLE
-- ============================================

local function toggleOrbit(state)

    orbitEnabled = state

    if state then

        enableOrbit()

    else

        disableOrbit()
    end
end

-- ============================================
-- UI
-- ============================================

OrbitBox:AddDropdown(
    "OrbitTarget",
{
    Text = "Target",

    Values = orbitPlayerList,

    Default = nil,

    Callback = function(value)

        orbitTarget = value
    end
})

OrbitBox:AddToggle(
    "OrbitToggle",
{
    Text = "Orbit",

    Default = false,

    Tooltip = "Orbit around player.",

    Callback = function(state)

        toggleOrbit(state)
    end
})

OrbitBox:AddSlider(
    "OrbitSpeed",
{
    Text = "Orbit Speed",

    Default = 5,

    Min = 1,
    Max = 50,

    Rounding = 0,

    Callback = function(value)

        orbitSpeed = value
    end
})

-- ============================================
-- KEYBINDS
-- ============================================

UserInputService.InputBegan:Connect(function(input, gp)

    if gp then
        return
    end

    -- K = Fly + Noclip

    if input.KeyCode == Enum.KeyCode.K then

        Toggles.Fly:SetValue(
            not Toggles.Fly.Value
        )

        Toggles.Noclip:SetValue(
            not Toggles.Noclip.Value
        )

        Library:Notify({

            Title = "MOVEMENT",

            Description =
                Toggles.Fly.Value
                and "Fly Enabled"
                or "Fly Disabled",

            Time = 3

        })

    end

    -- Y = Orbit

    if input.KeyCode == Enum.KeyCode.Y then

        Toggles.OrbitToggle:SetValue(
            not Toggles.OrbitToggle.Value
        )

        Library:Notify({

            Title = "ORBIT",

            Description =
                Toggles.OrbitToggle.Value
                and "Orbit Enabled"
                or "Orbit Disabled",

            Time = 3

        })

    end

    -- P = ESP ALL

    if input.KeyCode == Enum.KeyCode.P then

        local state =
            not Toggles.ESPplayers.Value

        Toggles.ESPplayers:SetValue(state)
        Toggles.PlayerChams:SetValue(state)
        Toggles.PlayerName:SetValue(state)
        Toggles.PlayerHealth:SetValue(state)
        Toggles.PlayerDistance:SetValue(state)

        Library:Notify({

            Title = "ESP",

            Description =
                state
                and "ESP Enabled"
                or "ESP Disabled",

            Time = 3

        })

    end

    -- J = Infinite Jump

    if input.KeyCode == Enum.KeyCode.J then

        Toggles.InfiniteJump:SetValue(
            not Toggles.InfiniteJump.Value
        )

        Library:Notify({

            Title = "INFINITE JUMP",

            Description =
                Toggles.InfiniteJump.Value
                and "Enabled"
                or "Disabled",

            Time = 3

        })

    end

end)
