local function applyJumpPower(humanoid)
    if not humanoid then
        return
    end

    humanoid.UseJumpPower = true
    humanoid.JumpPower = customJumpPower
end

local function setupHumanoid(humanoid)
    if jumpConnection then
        jumpConnection:Disconnect()
        jumpConnection = nil
    end

    applyJumpPower(humanoid)

    jumpConnection = humanoid:GetPropertyChangedSignal("JumpPower"):Connect(function()
        if jumpPowerEnabled and humanoid.JumpPower ~= customJumpPower then
            humanoid.JumpPower = customJumpPower
        end
    end)
end

local function enableJumpPower()
    local char = player.Character
    if not char then
        return
    end

    local humanoid = char:FindFirstChildOfClass("Humanoid")
