local noclipCharacterConnection = nil

-- ============================================
-- GET CHARACTER
-- ============================================

local function getCharacter()

    local char =
        LocalPlayer.Character

    if not char then
        return nil
    end

    local humanoid =
        char:FindFirstChildOfClass("Humanoid")

    if not humanoid then
        return nil
    end

    return char
end

-- ============================================
-- SET NOCLIP
-- ============================================

local function applyNoclip(char)

    for _, obj in ipairs(char:GetDescendants()) do

        if obj:IsA("BasePart") then

            -- KHÔNG đụng Tool handle
            if obj.Parent:IsA("Tool") then
                continue
            end

            -- KHÔNG đụng accessories
            if obj.Parent:IsA("Accessory") then
                continue
            end

            pcall(function()

                obj.CanCollide = false

            end)
        end
    end
end

-- ============================================
-- RESTORE COLLISION
-- ============================================

local function restoreCollision(char)

    for _, obj in ipairs(char:GetDescendants()) do

        if obj:IsA("BasePart") then

            if obj.Parent:IsA("Tool") then
                continue
            end

            if obj.Parent:IsA("Accessory") then
                continue
            end

            pcall(function()

                obj.CanCollide = true

            end)
        end
    end
end

-- ============================================
-- ENABLE
-- ============================================

local function enableNoclip()

    if noclipConnection then

        noclipConnection:Disconnect()
        noclipConnection = nil
    end

    noclipConnection =
        RunService.Heartbeat:Connect(function()

            local char =
                getCharacter()

            if not char then
                return
            end

            applyNoclip(char)
        end)

    -- RESPAWN SUPPORT

    if noclipCharacterConnection then

        noclipCharacterConnection:Disconnect()
        noclipCharacterConnection = nil
    end

    noclipCharacterConnection =
        LocalPlayer.CharacterAdded:Connect(function()

            task.wait(1)

            if noclipEnabled then

                local char =
                    getCharacter()

                if char then
                    applyNoclip(char)
                end
            end
        end)
end

-- ============================================
-- DISABLE
-- ============================================

local function disableNoclip()

    if noclipConnection then

        noclipConnection:Disconnect()
        noclipConnection = nil
    end

    if noclipCharacterConnection then

        noclipCharacterConnection:Disconnect()
        noclipCharacterConnection = nil
    end

    local char =
        getCharacter()

    if char then

        restoreCollision(char)
    end
end

-- ============================================
-- TOGGLE
-- ============================================

local function toggleNoclip(state)

    noclipEnabled = state

    if state then

        enableNoclip()

    else

        disableNoclip()
    end
end

