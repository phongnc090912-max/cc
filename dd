        HorrorGui:Destroy()
    end

    HorrorGui = Instance.new("ScreenGui")
    HorrorGui.Name = "HORROR_GUI"
    HorrorGui.IgnoreGuiInset = true
    HorrorGui.ResetOnSpawn = false
    HorrorGui.Parent = game.Players.LocalPlayer.PlayerGui

    local Text = Instance.new("TextLabel")
    Text.Size = UDim2.new(1,0,1,0)
    Text.BackgroundTransparency = 1
    Text.Text = "SYSTEM 67 ERROR-ERROR 367"
    Text.Font = Enum.Font.Arcade
    Text.TextScaled = true
    Text.TextColor3 = Color3.fromRGB(255,0,0)
    Text.TextStrokeTransparency = 0
    Text.TextStrokeColor3 = Color3.fromRGB(0,0,0)
    Text.Parent = HorrorGui

    -- GLITCH LOOP
    task.spawn(function()

        while HorrorGui and HorrorGui.Parent and Enabled do

            Text.Position = UDim2.new(
                0,
                math.random(-25,25),
                0,
                math.random(-25,25)
            )

            Text.Rotation = math.random(-4,4)

            Text.TextTransparency = math.random(0,30)/100

            Text.TextColor3 = Color3.fromRGB(
                math.random(180,255),
                0,
                0
            )

            task.wait(0.03)

        end

    end)

    -- AUTO REMOVE
    task.delay(3,function()

        if HorrorGui then

            TweenService:Create(
                Text,
                TweenInfo.new(1),
                {
                    TextTransparency = 1
                }
            ):Play()

            task.wait(1)

            if HorrorGui then
                HorrorGui:Destroy()
                HorrorGui = nil
            end

        end

    end)

end

local function infectMap(enable)

    if enable then

        for _,v in pairs(workspace:GetDescendants()) do

            if v:IsA("BasePart") then

                if not ModifiedTextures[v] then

                    ModifiedTextures[v] = {
                        Material = v.Material,
                        Color = v.Color
                    }

                end

                -- DARK RED
                v.Material = Enum.Material.SmoothPlastic
                v.Color = Color3.fromRGB(20,0,0)

                -- REMOVE OLD
                for _,x in pairs(v:GetChildren()) do
                    if x.Name == "HACKER_TEXTURE" then
                        x:Destroy()
                    end
                end

                -- ALL SIDES
                for _,face in pairs(Enum.NormalId:GetEnumItems()) do

                    local tex = Instance.new("Texture")

                    tex.Name = "HACKER_TEXTURE"
                    tex.Texture = HackerImage
                    tex.Face = face

                    tex.StudsPerTileU = 8
                    tex.StudsPerTileV = 8

                    tex.Transparency = 0.05

                    tex.Parent = v

                end

            end

        end

    else

        for obj,data in pairs(ModifiedTextures) do

            if obj and obj.Parent then

                obj.Material = data.Material
                obj.Color = data.Color

                for _,x in pairs(obj:GetChildren()) do

                    if x.Name == "HACKER_TEXTURE" then
                        x:Destroy()
                    end

                end

            end

        end

        table.clear(ModifiedTextures)

    end

end

--// EFFECT LOOP
task.spawn(function()

    while true do

        if Enabled then

            -- SKYBOX
            applySkybox(HackerImage)

            -- DARK WORLD
            Lighting.ClockTime = 0

            -- HARD GLITCH BRIGHTNESS
            Lighting.Brightness = math.random(0,8)

            Lighting.Ambient = Color3.fromRGB(
                math.random(80,255),
                0,
                0
            )

            Lighting.OutdoorAmbient = Color3.fromRGB(
                math.random(20,120),
                0,
                0
            )

        end

        task.wait(0.05)

    end

end)

--// TOGGLE
SkyChangerBox:AddToggle("HackerSkyTroll", {

    Text = "Hacker Sky Troll",
    Default = false,
    Tooltip = "Corrupts the map with glitch effects.",

    Callback = function(state)

        Enabled = state

        if state then

            createHorrorMessage()

            applySkybox(HackerImage)

            infectMap(true)

            TweenService:Create(
                Lighting,
                TweenInfo.new(0.4),
                {
                    Brightness = 0
                }
            ):Play()

        else

            infectMap(false)

            -- RESET
            Lighting.Brightness = Original.Brightness
            Lighting.ClockTime = Original.ClockTime
            Lighting.Ambient = Original.Ambient
            Lighting.OutdoorAmbient = Original.OutdoorAmbient

            applySkybox("rbxassetid://159454299")

            if HorrorGui then
                HorrorGui:Destroy()
                HorrorGui = nil
            end

        end

    end

})
