        player.Character
    if not char then
        return nil
    end
    return char:FindFirstChild(
        "HumanoidRootPart"
    )
end

-- ============================================
-- PLAYER LIST
-- ============================================

local orbitPlayerList = {}

local function updateOrbitPlayerList()

    table.clear(
        orbitPlayerList
    )

    for _, player in ipairs(
        Players:GetPlayers()
    ) do

        if player ~= LocalPlayer then

            table.insert(
                orbitPlayerList,
                player.Name
            )
        end
    end

    if Options.OrbitTarget then

        Options.OrbitTarget:SetValues(
            orbitPlayerList
        )
    end
end

Players.PlayerAdded:Connect(function()

    task.wait(1)

    updateOrbitPlayerList()
end)

Players.PlayerRemoving:Connect(function()

    task.wait(1)

    updateOrbitPlayerList()
end)

updateOrbitPlayerList()

-- ============================================
-- ENABLE
-- ============================================

local function enableOrbit()

    if orbitConnection then

        orbitConnection:Disconnect()

        orbitConnection = nil
    end

    orbitConnection =
        RunService.Heartbeat:Connect(function()

            if not orbitEnabled then
                return
            end

            if not orbitTarget then
                return
            end

            local target =
                Players:FindFirstChild(
                    orbitTarget
                )

            if not target then
                return
            end

            local myRoot =
                getRoot(LocalPlayer)

            local targetRoot =
                getRoot(target)

            if not myRoot
            or not targetRoot then
                return
            end

            -- ====================================
            -- CLOSE ORBIT
            -- ====================================

            local radius = 5

            local t =
                tick()
                * orbitSpeed

            local x =
                math.cos(t)
                * radius

            local z =
                math.sin(t)
                * radius

            -- ====================================
            -- FIX UNDERGROUND BUG
            -- ====================================

            local position =
                targetRoot.Position
                + Vector3.new(
                    x,
                    1.5,
                    z
                )

            -- ====================================
            -- MOVE
            -- ====================================

            myRoot.CFrame =
                CFrame.lookAt(
                    position,
                    targetRoot.Position
                )

            myRoot.AssemblyLinearVelocity =
                Vector3.zero
        end)
end

-- ============================================
-- DISABLE
-- ============================================

local function disableOrbit()

    if orbitConnection then

        orbitConnection:Disconnect()

        orbitConnection = nil
    end
end

-- ============================================
-- TOGGLE
-- ============================================

local function toggleOrbit(state)

    orbitEnabled = state

    if state then

        enableOrbit()

    else

        disableOrbit()
    end
end

