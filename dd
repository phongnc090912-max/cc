-- ============================================
-- COLORS
-- ============================================

local function getDistanceColor(dist)
    if dist > 250 then
        return Color3.fromRGB(255,80,80)

    elseif dist > 150 then
        return Color3.fromRGB(255,180,80)

    elseif dist > 75 then
        return Color3.fromRGB(255,255,80)

    else
        return Color3.fromRGB(220,220,220)
    end
end

local function getHealthColor(percent)
    if percent > 0.6 then
        return Color3.fromRGB(80,255,80)

    elseif percent > 0.3 then
        return Color3.fromRGB(255,220,50)

    else
        return Color3.fromRGB(255,60,60)
    end
end

-- ============================================
-- REMOVE ESP
-- ============================================

local function removePlayerESP(player)

    local esp = playerESPInstances[player]

    if esp then

        if esp.Highlight then
            esp.Highlight:Destroy()
        end

        if esp.Billboard then
            esp.Billboard:Destroy()
        end

        if esp.Connection then
            esp.Connection:Disconnect()
        end

        playerESPInstances[player] = nil
    end
end

-- ============================================
-- CREATE ESP
-- ============================================

local function createPlayerESP(player)

    if player == LocalPlayer then
        return
    end

    if playerESPInstances[player] then
        return
    end

    local char = player.Character

    if not char then
        return
    end

    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")

    if not root or not humanoid then
        return
    end

    local espTable = {}

    -- ========================================
    -- HIGHLIGHT
    -- ========================================

    if playerESPVars.Chams then

        local highlight = Instance.new("Highlight")

        highlight.Name = "PlayerESP"
        highlight.Adornee = char

        highlight.FillColor = Color3.fromRGB(0,100,255)
        highlight.FillTransparency = 0.5

        highlight.OutlineColor = Color3.fromRGB(255,255,255)
        highlight.OutlineTransparency = 0

        highlight.Parent = char

        espTable.Highlight = highlight
    end

    -- ========================================
    -- BILLBOARD
    -- ========================================

    local billboard
    local nameLabel
    local healthLabel
    local distLabel

    if playerESPVars.Name
    or playerESPVars.Health
    or playerESPVars.Distance then

        billboard = Instance.new("BillboardGui")

        billboard.Name = "PlayerESP_UI"
        billboard.Adornee = root
        billboard.Size = UDim2.new(0,220,0,70)
        billboard.StudsOffset = Vector3.new(0,3,0)
        billboard.AlwaysOnTop = true
        billboard.Parent = char

        local frame = Instance.new("Frame")

        frame.Size = UDim2.new(1,0,1,0)
        frame.BackgroundTransparency = 1
        frame.Parent = billboard

        -- NAME

        nameLabel = Instance.new("TextLabel")

        nameLabel.Size = UDim2.new(1,0,0.33,0)
        nameLabel.Position = UDim2.new(0,0,0,0)

        nameLabel.BackgroundTransparency = 1

        nameLabel.Text = player.Name
        nameLabel.TextColor3 = Color3.fromRGB(150,200,255)

        nameLabel.TextStrokeTransparency = 0
        nameLabel.TextStrokeColor3 = Color3.fromRGB(0,0,0)

        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextSize = 14

        nameLabel.Visible = playerESPVars.Name

        nameLabel.Parent = frame

        -- HEALTH

        healthLabel = Instance.new("TextLabel")

        healthLabel.Size = UDim2.new(1,0,0.33,0)
        healthLabel.Position = UDim2.new(0,0,0.33,0)

        healthLabel.BackgroundTransparency = 1

        healthLabel.Text = "100 HP"

        healthLabel.TextStrokeTransparency = 0
        healthLabel.TextStrokeColor3 = Color3.fromRGB(0,0,0)

        healthLabel.Font = Enum.Font.GothamBold
        healthLabel.TextSize = 13

        healthLabel.Visible = playerESPVars.Health

        healthLabel.Parent = frame

        -- DISTANCE

        distLabel = Instance.new("TextLabel")

        distLabel.Size = UDim2.new(1,0,0.33,0)
        distLabel.Position = UDim2.new(0,0,0.66,0)

        distLabel.BackgroundTransparency = 1

        distLabel.Text = "0m"

        distLabel.TextStrokeTransparency = 0
        distLabel.TextStrokeColor3 = Color3.fromRGB(0,0,0)

        distLabel.Font = Enum.Font.GothamBold
        distLabel.TextSize = 12

        distLabel.Visible = playerESPVars.Distance

        distLabel.Parent = frame

        espTable.Billboard = billboard
    end

    -- ========================================
    -- UPDATE LOOP
    -- ========================================

    local connection

    connection = RunService.Heartbeat:Connect(function()

        if not player.Parent then
            removePlayerESP(player)
            connection:Disconnect()
            return
        end

        local char = player.Character

        if not char then
            return
        end

        local root = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChildOfClass("Humanoid")

        local myChar = LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

        if not root or not humanoid or not myRoot then
            return
        end

        local distance =
            (myRoot.Position - root.Position).Magnitude

        -- HEALTH %

        local healthPercent =
            humanoid.Health / humanoid.MaxHealth

        local healthColor =
            getHealthColor(healthPercent)

        -- UPDATE HEALTH COLOR

        if espTable.Highlight then

            espTable.Highlight.FillColor =
                healthColor
        end

        -- UPDATE TEXTS

        if nameLabel then
            nameLabel.Text = player.Name
        end

        if healthLabel then

            healthLabel.Text =
                math.floor(humanoid.Health)
                .. " HP"

            healthLabel.TextColor3 =
                healthColor
        end

        if distLabel then

            distLabel.Text =
                math.floor(distance)
                .. "m"

            distLabel.TextColor3 =
                getDistanceColor(distance)
        end
    end)

    espTable.Connection = connection

    playerESPInstances[player] = espTable
end

-- ============================================
-- REFRESH ESP
-- ============================================

local function refreshPlayerESP()

    for player, _ in pairs(playerESPInstances) do
        removePlayerESP(player)
    end

    if not playerESPVars.ESP then
        return
    end

    for _, player in ipairs(Players:GetPlayers()) do

        if player ~= LocalPlayer then

            createPlayerESP(player)

            player.CharacterAdded:Connect(function()

                task.wait(1)

                if playerESPVars.ESP then
                    createPlayerESP(player)
                end
            end)
        end
    end
end

