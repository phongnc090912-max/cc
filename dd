-- ============================================
-- ORBIT SYSTEM
-- ============================================

-- ============================================
-- SYSTEM VARIABLES
-- ============================================

local orbitEnabled = false

local orbitConnection = nil

local orbitTarget = nil

local orbitRadius = 10
local orbitSpeed = 2
local orbitHeight = 3

local orbitReverse = false

-- ============================================
-- GET ROOT
-- ============================================

local function getRoot(player)

    if not player then
        return nil
    end

    local char =
        player.Character

    if not char then
        return nil
    end

    return char:FindFirstChild(
        "HumanoidRootPart"
    )
end

-- ============================================
-- ENABLE
-- ============================================

local function enableOrbit()

    if orbitConnection then

        orbitConnection:Disconnect()
        orbitConnection = nil
    end

    orbitConnection =
        RunService.Heartbeat:Connect(function()

            if not orbitEnabled then
                return
            end

            if not orbitTarget then
                return
            end

            local target =
                Players:FindFirstChild(
                    orbitTarget
                )

            if not target then
                return
            end

            local myRoot =
                getRoot(LocalPlayer)

            local targetRoot =
                getRoot(target)

            if not myRoot
            or not targetRoot then
                return
            end

            -- ====================================
            -- TIME
            -- ====================================

            local t =
                tick() * orbitSpeed

            if orbitReverse then
                t = -t
            end

            -- ====================================
            -- POSITION
            -- ====================================

            local x =
                math.cos(t)
                * orbitRadius

            local z =
                math.sin(t)
                * orbitRadius

            local orbitPosition =
                targetRoot.Position
                + Vector3.new(
                    x,
                    orbitHeight,
                    z
                )

            -- ====================================
            -- LOOK AT TARGET
            -- ====================================

            myRoot.CFrame =
                CFrame.lookAt(
                    orbitPosition,
                    targetRoot.Position
                )

            myRoot.AssemblyLinearVelocity =
                Vector3.zero
        end)
end

-- ============================================
-- DISABLE
-- ============================================

local function disableOrbit()

    if orbitConnection then

        orbitConnection:Disconnect()
        orbitConnection = nil
    end
end

-- ============================================
-- TOGGLE
-- ============================================

local function toggleOrbit(state)

    orbitEnabled = state

    if state then

        enableOrbit()

    else

        disableOrbit()
    end
end

